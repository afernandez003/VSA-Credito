{
  "openapi": "3.1.1",
  "info": {
    "title": "Creditos API — Desafio Técnico",
    "description": "API REST para integração e consulta de créditos constituídos (ISSQN/NFS-e).",
    "version": "v1"
  },
  "paths": {
    "/self": {
      "get": {
        "tags": [
          "Creditos.Api"
        ],
        "summary": "Liveness — verifica se o processo está ativo",
        "operationId": "Self",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnonymousTypeOfstring"
                }
              }
            }
          }
        }
      }
    },
    "/ready": {
      "get": {
        "tags": [
          "Creditos.Api"
        ],
        "summary": "Readiness — verifica se o banco de dados está acessível",
        "operationId": "Ready",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/creditos/integrar-credito-constituido": {
      "post": {
        "tags": [
          "Creditos"
        ],
        "summary": "Integra uma lista de créditos constituídos publicando no tópico Kafka",
        "operationId": "IntegrarCredito",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/CreditoRequest"
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "Accepted"
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/HttpValidationProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/creditos/{numeroNfse}": {
      "get": {
        "tags": [
          "Creditos"
        ],
        "summary": "Retorna créditos constituídos pelo número da NFS-e",
        "operationId": "GetCreditosByNfse",
        "parameters": [
          {
            "name": "numeroNfse",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Response"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/creditos/credito/{numeroCredito}": {
      "get": {
        "tags": [
          "Creditos"
        ],
        "summary": "Retorna os detalhes de um crédito constituído pelo seu número",
        "operationId": "GetCreditoByNumero",
        "parameters": [
          {
            "name": "numeroCredito",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Response"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    }
  },
